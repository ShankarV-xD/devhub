    "@types/jsonpath": "^0.2.4",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/zxcvbn": "^4.4.5",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "colord": "^2.9.3",
    "cronstrue": "^3.9.0",
    "crypto-js": "^4.2.0",
    "csso": "^5.0.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.3.1",
    "fast-xml-parser": "^5.3.4",
    "figlet": "^1.10.0",
    "graphql": "^16.12.0",
    "jose": "^6.1.3",
    "json-to-ts": "^2.1.0",
    "jsonpath": "^1.1.1",
    "lorem-ipsum": "^2.0.8",
    "lucide-react": "^0.562.0",
    "lz-string": "^1.5.0",
    "next": "16.1.1",
    "next-pwa": "^5.6.0",
    "papaparse": "^5.5.3",
    "posthog-js": "^1.332.0",
    "prettier": "^3.8.1",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-colorful": "^5.6.1",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "react-swipeable": "^7.0.2",
    "react-virtualized-auto-sizer": "^2.0.2",
    "react-window": "^2.2.5",
    "sonner": "^2.0.7",
    "sql-formatter": "^15.6.12",
    "tailwind-merge": "^3.4.0",
    "xml-formatter": "^3.6.7",
    "yaml": "^2.8.2",
    "zod": "^4.3.5",
    "zustand": "^5.0.10",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.4",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
